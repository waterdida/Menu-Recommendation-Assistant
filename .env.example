# LLM provider, Moonshot-compatible OpenAI API
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_API_BASE_URL=https://api.moonshot.cn/v1

# Neo4j, started by data/docker-compose.yml
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=all-in-rag
NEO4J_DATABASE=neo4j

# Milvus, started by docker-compose.yml
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=cooking_knowledge
MILVUS_DIMENSION=512

# Model settings
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LLM_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Retrieval and generation
TOP_K=5
MAX_GRAPH_DEPTH=2
TEMPERATURE=0.2
MAX_TOKENS=1024
CHUNK_SIZE=500
CHUNK_OVERLAP=50
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Logging
LOG_LEVEL=INFO
